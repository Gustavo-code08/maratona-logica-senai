programa {
  funcao inicio() {
    inteiro senha
    cadeia usuario
    escreva("Qual é o nome de usuário: ")
    leia(usuario)
    escreva("Qual é a senha: ")
    leia(senha)
    se (usuario == "admin" e senha == 1234)
    escreva("Acesso concedido")
    senao
    escreva("Acesso negado")
    
  }
}
