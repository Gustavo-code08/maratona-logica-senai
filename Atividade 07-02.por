programa {
  funcao inicio() {
    inteiro p1,p2,soma
    escreva("Qual a quantidade da primeira remessa de parafusos: ")
    leia(p1)
    escreva("Qual a quantidade da segunda remessa de parafusos: ")
    leia(p2)
    soma = p1 + p2
    escreva("O estoque total disponível é de ", soma, " parafusos")
  }
}
