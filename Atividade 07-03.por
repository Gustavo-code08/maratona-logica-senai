programa {
  funcao inicio() {
    real n1,n2,resultado
    escreva("Qual é o valor da sua hora técnica: ")
    leia(n1)
    escreva("Quantas horas você levou para concluir o serviço: ")
    leia(n2)
    resultado = n1 * n2
    escreva("O valor total a ser pago pelo serviço é: R$", resultado)

  }
}
