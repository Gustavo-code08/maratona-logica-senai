programa {
  funcao inicio() {
    inteiro senha=2008

    escreva("Digite a senha: ")
    leia(senha)

    enquanto(senha != 2008){
    escreva("SENHA INCORRETA, Tente novamente \n")

    escreva("Digite a senha: ")
    leia(senha)}

    se(senha==2008)
    escreva("Acesso liberado")



    
  }
}
