programa {
  funcao inicio() {
    real largura, comprimento, area
    escreva("Qual é a largura do galpão em metros: ")
    leia(largura)
    escreva("Qual é o comprimento do galpão em metros: ")
    leia(comprimento)
    area = comprimento * largura
    escreva("A área do galpão é ", area, "m²")

  }
}
